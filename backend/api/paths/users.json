{
  "me": {
    "get": {
      "summary": "Get My Profile",
      "tags": ["Profile"],
      "responses": {
        "200": {
          "description": "Success Response",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "$ref": "../schemas/common.json#/User" }
                }
              }
            }
          }
        }
      }
    },
    "patch": {
      "summary": "Update Profile",
      "description": "Partial update for user profile. PATCH is used because it updates only specific fields without replacing the entire object.",
      "tags": ["Profile"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "example": "Gilang Baru" },
                "phone": { "type": "string", "example": "081111111" },
                "profile_picture": { "type": "string", "example": "profile-1.jpg" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "me-password": {
    "patch": {
      "summary": "Update Password",
      "tags": ["Profile"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "current_password": { "type": "string", "example": "passwordlama" },
                "new_password": { "type": "string", "example": "passwordbaru" },
                "confirm_password": { "type": "string", "example": "passwordbaru" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" },
        "400": { "$ref": "../responses/common.json#/GenericError" }
      }
    }
  },
  "me-profile-picture": {
    "delete": {
      "summary": "Delete Profile Picture",
      "tags": ["Profile"],
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "request-email-otp": {
    "post": {
      "summary": "Request Email Change OTP",
      "tags": ["Profile"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "new_email": { "type": "string", "example": "gilang_baru@gmail.com" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "me-email": {
    "put": {
      "summary": "Verify OTP & Update Email",
      "tags": ["Profile"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "otp": { "type": "string", "example": "123456" },
                "new_email": { "type": "string", "example": "gilang_baru@gmail.com" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" },
        "400": { "$ref": "../responses/common.json#/GenericError" }
      }
    }
  },
  "root": {
    "get": {
      "summary": "Get All Users (Admin/Manager)",
      "description": "Fetch a list of all users in the system. Admin can see everyone (including other Admins, Managers, Cashiers, and Customers). Manager can only see employees in their branch.",
      "tags": ["Users (Employee Management)"],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": { "$ref": "../schemas/common.json#/User" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "managers": {
    "post": {
      "summary": "Create Manager (Admin Only)",
      "tags": ["Users (Employee Management)"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "branch_id": { "type": "integer", "example": 1 },
                "name": { "type": "string", "example": "Budi Manager" },
                "email": { "type": "string", "example": "manager@example.com" },
                "password": { "type": "string", "example": "password123" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "cashiers": {
    "post": {
      "summary": "Create Cashier (Manager Only)",
      "tags": ["Users (Employee Management)"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "example": "Siti Kasir" },
                "email": { "type": "string", "example": "kasir@example.com" },
                "password": { "type": "string", "example": "password123" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "user-disable": {
    "patch": {
      "summary": "Disable/Deactivate User (Admin Only)",
      "tags": ["Users (Employee Management)"],
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  }
}
