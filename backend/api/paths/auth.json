{
  "register": {
    "post": {
      "summary": "Register Customer",
      "tags": ["Auth"],
      "security": [],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "example": "Gilang" },
                "email": { "type": "string", "example": "gilang@gmail.com" },
                "password": { "type": "string", "example": "rahasia123" },
                "confirm_password": { "type": "string", "example": "rahasia123" },
                "phone": { "type": "string", "example": "08123456789" }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Success Response",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "example": "uuid" },
                      "name": { "type": "string", "example": "Gilang" },
                      "email": { "type": "string", "example": "gilang@gmail.com" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "login": {
    "post": {
      "summary": "Login",
      "tags": ["Auth"],
      "security": [],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "email": { "type": "string", "example": "gilang@gmail.com" },
                "password": { "type": "string", "example": "rahasia123" },
                "remember_me": { "type": "boolean", "example": true }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Success Response",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "token": { "type": "string", "example": "jwt_token" },
                      "user": { "$ref": "../schemas/common.json#/User" }
                    }
                  }
                }
              }
            }
          }
        },
        "401": { "$ref": "../responses/common.json#/GenericError" }
      }
    }
  },
  "logout": {
    "delete": {
      "summary": "Logout",
      "tags": ["Auth"],
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "forgot-password": {
    "post": {
      "summary": "Forgot Password",
      "tags": ["Auth"],
      "security": [],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "email": { "type": "string", "example": "gilang@gmail.com" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "reset-password": {
    "post": {
      "summary": "Reset Password",
      "tags": ["Auth"],
      "security": [],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "token": { "type": "string", "example": "123456" },
                "new_password": { "type": "string", "example": "passwordbaru" },
                "confirm_password": { "type": "string", "example": "passwordbaru" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  }
}
