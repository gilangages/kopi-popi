                    "type": "string",
                    "example": "gilang@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "rahasia123"
                  },
                  "confirm_password": {
                    "type": "string",
                    "example": "rahasia123"
                  },
                  "phone": {
                    "type": "string",
                    "example": "08123456789"
