                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "uuid"
                        },
                        "name": {
                          "type": "string",
                          "example": "Gilang"
                        },
                        "email": {
                          "type": "string",
                          "example": "gilang@gmail.com"
