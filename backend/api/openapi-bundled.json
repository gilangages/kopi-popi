  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "profile_picture": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "Invalid request or unauthorized"
              }
            }
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "example": "Kopi"
          }
        }
      },
      "CategoryRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Kopi"
          }
        }
      },
      "Material": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "category_id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "example": "Biji Kopi Arabica"
          },
          "unit": {
            "type": "string",
            "example": "gram"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MaterialRequest": {
        "type": "object",
        "required": [
          "category_id",
          "name",
          "unit"
        ],
        "properties": {
          "category_id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Biji Kopi Arabica"
          },
          "unit": {
            "type": "string",
            "example": "gram"
          }
        }
      },
      "ProductBOM": {
        "type": "object",
        "properties": {
          "material_id": {
            "type": "integer",
            "example": 1
          },
          "quantity_needed": {
            "type": "number",
            "format": "float",
            "example": 15.5
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "category_id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "example": "Kopi Susu Aren"
          },
          "description": {
            "type": "string",
            "example": "Perpaduan espresso dan aren manis"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 20000
          },
          "image_url": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "recipe": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductBOM"
            }
          }
        }
      },
      "ProductRequest": {
        "type": "object",
        "required": [
          "category_id",
          "name",
          "price",
          "recipe"
        ],
        "properties": {
          "category_id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Kopi Susu Aren"
          },
          "description": {
            "type": "string",
            "example": "Perpaduan espresso dan aren manis"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 20000
          },
          "image_url": {
            "type": "string",
            "example": "https://example.com/kopi.jpg"
          },
          "is_active": {
            "type": "boolean",
            "example": true
          },
          "recipe": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductBOM"
            },
            "description": "BOM/Resep bahan baku yang dibutuhkan"
          }
        }
      },
      "Branch": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateBranchRequest": {
        "type": "object",
        "required": [
          "name",
          "address"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Cabang Bandung"
          },
          "address": {
            "type": "string",
            "example": "Jl. Braga No. 10, Bandung"
          }
        }
      },
      "UpdateBranchRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Cabang Bandung Baru"
          },
          "address": {
            "type": "string",
            "example": "Jl. Braga No. 15, Bandung"
          },
          "is_active": {
            "type": "boolean",
            "example": true
          }
        }
      }
    },
    "responses": {
      "GenericError": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "GenericSuccess": {
        "description": "Success operation",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Operation success"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}