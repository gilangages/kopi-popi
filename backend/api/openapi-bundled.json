    "/auth/register": {
      "post": {
        "summary": "Register Customer",
        "tags": [
          "Auth"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Gilang"
                  },
                  "email": {
                    "type": "string",
                    "example": "gilang@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "rahasia123"
                  },
                  "confirm_password": {
                    "type": "string",
                    "example": "rahasia123"
                  },
                  "phone": {
                    "type": "string",
                    "example": "08123456789"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "uuid"
                        },
                        "name": {
                          "type": "string",
                          "example": "Gilang"
                        },
                        "email": {
                          "type": "string",
                          "example": "gilang@gmail.com"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
