    "/uploads": {
      "post": {
        "summary": "Upload a File",
        "description": "Upload a file to the server. Supports JPG, JPEG, PNG, and WEBP. Maximum size is 5MB.",
        "tags": [
          "Media"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload (Max 5MB)"
                  },
                  "folder": {
                    "type": "string",
                    "description": "Optional subfolder name (e.g. 'products', 'profiles')",
                    "default": "misc"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "file uploaded successfully"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "type": "string",
                          "example": "http://localhost:8080/uploads/products/1689328293.jpg"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/GenericError"
          }
        }
      }
    },
